# ─── Backend ──────────────────────────────────
PORT=3001
HOST=127.0.0.1
DB_PATH=./data/k6-dashboard.db
K6_SCRIPT_PATH=k6-scripts/cross-domain-login.js
K6_BINARY_PATH=k6
MAX_CONCURRENT_TESTS=3
ENCRYPTION_KEY=change-me-to-a-32-char-key-here!

# ─── InfluxDB (optional — enables Grafana integration) ────
# Set this to enable dual-output: K6 → InfluxDB + JSON
# INFLUXDB_URL=http://localhost:8086/k6

# ─── Frontend ─────────────────────────────────
VITE_API_URL=http://127.0.0.1:3001
VITE_WS_URL=ws://127.0.0.1:3001
# VITE_GRAFANA_URL=http://localhost:3000

