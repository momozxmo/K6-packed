      "title": "RESPONSE TIME DISTRIBUTION (HISTOGRAM)",
      "type": "barchart",
      "transformations": [],
      "targets": [
        {
          "alias": "0-100ms",
          "groupBy": [],
          "measurement": "http_req_duration",
          "select": [[{ "params": ["value"], "type": "field" }, { "params": [], "type": "count" }]],
          "tags": [{ "key": "value", "operator": "<", "value": "100" }],
          "rawQuery": true,
          "query": "SELECT count(\"value\") AS \"0-100ms\" FROM \"http_req_duration\" WHERE $timeFilter AND \"value\" < 100"
        },
        {
          "alias": "100-200ms",
          "rawQuery": true,
          "query": "SELECT count(\"value\") AS \"100-200ms\" FROM \"http_req_duration\" WHERE $timeFilter AND \"value\" >= 100 AND \"value\" < 200"
        },
        {
          "alias": "200-500ms",
          "rawQuery": true,
          "query": "SELECT count(\"value\") AS \"200-500ms\" FROM \"http_req_duration\" WHERE $timeFilter AND \"value\" >= 200 AND \"value\" < 500"
        },
        {
          "alias": "500ms+",
          "rawQuery": true,
          "query": "SELECT count(\"value\") AS \"500ms+\" FROM \"http_req_duration\" WHERE $timeFilter AND \"value\" >= 500"
        }
